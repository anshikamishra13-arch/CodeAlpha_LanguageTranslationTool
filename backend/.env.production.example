# Production Environment Configuration Template
# Copy this to .env.production and fill in actual values

# ====== PRODUCTION DATABASE ======
MONGO_URI=mongodb+srv://YOUR_PROD_USER:YOUR_PROD_PASSWORD@your-cluster.mongodb.net/linguaai

# ====== PRODUCTION API KEYS ======
OPENAI_API_KEY=sk-proj-your-production-key
GEMINI_API_KEY=AIza-your-production-key

# ====== AUTHENTICATION ======
# Generate new JWT secret for production:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=generate-new-long-random-string-here

# ====== SERVER ======
PORT=443
NODE_ENV=production

# ====== CORS FOR PRODUCTION ======
# Update with your actual production domain(s)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,https://app.yourdomain.com

# ====== OPTIONAL MONITORING ======
# For error tracking (Sentry, etc.)
SENTRY_DSN=

# For analytics
ANALYTICS_KEY=

# Database backup URL (for automated backups)
BACKUP_URL=
