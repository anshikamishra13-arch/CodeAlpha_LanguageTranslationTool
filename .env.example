# Backend environment variables
# Copy this file to /backend/.env and fill in your values

# MongoDB connection string (get from MongoDB Atlas or local)
MONGO_URI=mongodb+srv://anshikamishra3112200_db_user:<db_password>@cluster0.ypaadah.mongodb.net/?appName=Cluster0

# OpenAI API key (get from https://platform.openai.com/api-keys)
