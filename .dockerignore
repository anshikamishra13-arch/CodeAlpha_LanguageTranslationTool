# ── Node modules (reinstalled inside Docker) ──
node_modules
**/node_modules

# ── Build outputs ──
**/dist
**/.vite

# ── Environment files (never bake secrets into images) ──
.env
.env.*
!.env.example

# ── Git / CI ──
.git
.gitignore
.github

# ── Logs & OS noise ──
*.log
npm-debug.log*
.DS_Store
Thumbs.db

# ── Dev-only docs / config ──
README.md
DEPLOYMENT*.md
PRODUCTION_READY.md
RENDER*.md
SECURITY.md
render.yaml
